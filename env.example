# ── Required ──────────────────────────────────────────────────────────────────
DERIV_API_TOKEN=your_deriv_api_token_here

# ── Symbol & Contract ─────────────────────────────────────────────────────────
SYMBOL=1HZ25V
# Other valid symbols: 1HZ10V, 1HZ100V, R_10, R_25, R_100

# ── Session Risk ──────────────────────────────────────────────────────────────
TARGET_PROFIT=50.0
STOP_LOSS=20.0

# ── Martingale ────────────────────────────────────────────────────────────────
MARTINGALE_BASE_STAKE=0.35
MARTINGALE_FACTOR=1.75
MARTINGALE_MAX_STEPS=4

# ── Entry Gate ────────────────────────────────────────────────────────────────
MIN_BIAS_EDGE=0.04
MIN_EV=0.005
TRADE_COOLDOWN=15

# ── Digit Bias Estimator ──────────────────────────────────────────────────────
BIAS_ALPHA=0.15
N_WINDOW=30
MIN_WARMUP_TICKS=60

# ── Live Recalibrator ─────────────────────────────────────────────────────────
CALM_FACTOR=0.85
NORMAL_FACTOR=1.25
RECAL_INTERVAL=300
RECAL_WINDOW=300

# ── Kelly Sizing ──────────────────────────────────────────────────────────────
KELLY_FRACTION=0.20
KELLY_MAX_PCT=0.04

# ── Railway sets PORT automatically — do not override ─────────────────────────
# PORT=8081
